{
  "name": "@dakota-xyz/ts-sdk",
  "version": "1.0.9",
  "description": "Official TypeScript SDK for Dakota Platform - stablecoin payments infrastructure",
  "author": "Dakota <support@dakota.xyz>",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./webhook": {
      "import": {
        "types": "./dist/webhook/index.d.ts",
        "default": "./dist/webhook/index.js"
      },
      "require": {
        "types": "./dist/webhook/index.d.cts",
        "default": "./dist/webhook/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate": "./scripts/generate.sh",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0"
  },
  "devDependencies": {
    "@noble/hashes": "^2.0.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "msw": "^2.1.0",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "dakota",
    "stablecoin",
    "payments",
    "crypto",
    "usdc",
    "usdt",
    "on-ramp",
    "off-ramp",
    "api",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dakota-xyz/ts-sdk.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/dakota-xyz/ts-sdk/issues"
  },
  "homepage": "https://docs.dakota.xyz"
}
